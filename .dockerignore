# .dockerignore

# Python virtual environment
.venv
venv/
**/venv/

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Node.js dependencies and build outputs
node_modules/
frontend/node_modules/
frontend/dist/

# Database and runtime data
data/
database.db
*.db-journal

# IDE and OS files
.vscode/
.idea/
.DS_Store

# Local environment files
.env
