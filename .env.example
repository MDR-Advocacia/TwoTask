# ─── Legal One (OData + OAuth client credentials) ───────────────────
LEGAL_ONE_BASE_URL=https://api.thomsonreuters.com/legalone/v1/api/rest
LEGAL_ONE_CLIENT_ID=SEU_ID_CLIENTE
LEGAL_ONE_CLIENT_SECRET=SUA_CHAVE_SECRETA

# ─── Legal One Web (RPA Playwright — tratamento de publicações) ─────
LEGAL_ONE_WEB_URL=https://app.legalone.com.br
LEGAL_ONE_WEB_USERNAME=
LEGAL_ONE_WEB_PASSWORD=
# Label da chave de acesso configurada na conta Legal One Web (exigida pelo RPA).
LEGAL_ONE_WEB_KEY_LABEL=

# ─── Banco de Dados (PostgreSQL) ────────────────────────────────────
# Em produção (Coolify) o host é "postgres" (nome do serviço no compose).
DATABASE_URL=postgresql+psycopg2://onetask:onetask@postgres:5432/onetask
POSTGRES_USER=onetask
POSTGRES_PASSWORD=troque_em_producao
POSTGRES_DB=onetask

# ─── API / Frontend ────────────────────────────────────────────────
# FRONTEND_PORT é a porta que o nginx do frontend expõe no host.
# Usando 8111 pra não colidir com outros stacks no Coolify.
# O proxy reverso do Coolify aponta pra essa porta.
FRONTEND_PORT=8111
# IMPORTANTE: gere uma chave forte em produção.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=troque_esta_chave_em_producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Domínios liberados pelo CORS (separados por vírgula). Em produção
# coloque o domínio público (ex.: https://onetask.mdradvocacia.com).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ─── Upload de planilhas ───────────────────────────────────────────
SPREADSHEET_MAX_SIZE_MB=10
SPREADSHEET_ALLOWED_CONTENT_TYPES=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/octet-stream

# ─── Worker de processamento em lote ───────────────────────────────
BATCH_WORKER_ENABLED=true
BATCH_WORKER_POLL_INTERVAL_SECONDS=5
BATCH_WORKER_LEASE_SECONDS=300

# ─── SMTP (notificações por email) ─────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=senha_de_app
EMAIL_FROM=seu@email.com
EMAIL_TO=destino@email.com

# ─── Classificador (Anthropic) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
CLASSIFIER_MAX_CONCURRENT=5
CLASSIFIER_MAX_TOKENS=1024

# ─── AJUS (sistema do cliente — POST /inserir-prazos) ─────────────
# Credenciais fornecidas pela equipe AJUS. Setar no painel do Coolify.
# Sem isso, o módulo AJUS fica inativo (intakes não são enfileirados;
# logs avisam que falta config).
AJUS_BASE_URL=https://sistema.ajus.com.br/webservices/api
AJUS_BEARER_TOKEN=
AJUS_CLIENTE=
AJUS_LOGIN=
AJUS_SENHA=
# Storage local de cópias do PDF da habilitação na fila AJUS. Sobrevive
# à rotina de cleanup do prazos_iniciais. Volume persistente do
# container — montado em /app/data/ajus_pdfs por default.
AJUS_STORAGE_PATH=/app/data/ajus_pdfs

# ─── Criar primeiro usuário (após subir) ───────────────────────────
# docker compose exec api python create_user.py --email voce@dominio.com --password trocar123
